---
import { Image } from "astro:assets";
import ThemeSwitcher from "../../components/ThemeSwitcher.astro";
import {
  contactDetails,
  experienceTimeline,
  openSourceLinks,
  portfolioIdentity,
  profileImages,
  theme4Content,
  workItems,
  writingArticles,
} from "../../content/portfolioContent.js";

const profileImage = profileImages.profile7;
const primaryArticle = writingArticles[0];
const heroProjects = [
  workItems.find(({ name }) => name === "Lucra Sports"),
  workItems.find(({ name }) => name === "Microsoft Flip"),
  workItems.find(({ name }) => name === "Rill Social"),
].filter(Boolean);
const work = workItems.map((item, index) => ({
  ...item,
  bundleClass: `bundle-tone-${(index % 3) + 1}`,
}));
const contactHrefMap = {
  email: `mailto:${contactDetails.email}`,
  stackOverflow: contactDetails.stackOverflow,
  github: contactDetails.github,
  linkedin: contactDetails.linkedin,
};
const toolGroups = theme4Content.skills.toolGroups;
---
<!DOCTYPE html>
<html lang="en" id="top">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{theme4Content.metaTitle}</title>
    <meta name="description" content={theme4Content.metaDescription} />
    <link rel="icon" type="image/png" href="/assets/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@400;500;600;700&family=Space+Grotesk:wght@500;700&display=swap"
      rel="stylesheet"
    />
    <style is:inline>
      *, *::before, *::after {
        box-sizing: border-box;
      }

      :root {
        --bg: #241a18;
        --bg-soft: #2e2220;
        --paper: #ede0d1;
        --paper-strong: #f7eee5;
        --surface: rgba(247, 238, 229, 0.88);
        --surface-strong: rgba(252, 246, 239, 0.96);
        --ink: #161210;
        --muted: #625852;
        --accent: #b65332;
        --accent-deep: #7e321d;
        --accent-soft: rgba(182, 83, 50, 0.12);
        --line: rgba(22, 18, 16, 0.12);
        --line-strong: rgba(22, 18, 16, 0.2);
        --shadow: 0 28px 80px rgba(0, 0, 0, 0.18);
        --max: 1220px;
        --radius-xl: 34px;
        --radius-lg: 26px;
        --radius-md: 20px;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        min-height: 100vh;
        font-family: "Public Sans", system-ui, sans-serif;
        color: var(--ink);
        background:
          radial-gradient(circle at 16% 0%, rgba(182, 83, 50, 0.24), transparent 26%),
          radial-gradient(circle at 84% 14%, rgba(126, 50, 29, 0.18), transparent 22%),
          linear-gradient(180deg, #2f2320 0%, var(--bg) 56%, #1a1211 100%);
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
      }

      body::before {
        content: "";
        position: fixed;
        inset: 0;
        background-image:
          linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
        background-size: 32px 32px;
        mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.7), transparent 78%);
        pointer-events: none;
      }

      a {
        color: inherit;
      }

      img {
        display: block;
        max-width: 100%;
      }

      .page {
        width: min(calc(100% - 28px), var(--max));
        margin: 18px auto 80px;
        background:
          linear-gradient(180deg, rgba(255, 250, 245, 0.98), rgba(237, 224, 209, 0.97));
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 40px;
        box-shadow: var(--shadow);
        overflow: hidden;
      }

      .topbar {
        position: sticky;
        top: 0;
        z-index: 20;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
        padding: 18px 24px;
        background: rgba(247, 238, 229, 0.92);
        border-bottom: 1px solid var(--line);
        backdrop-filter: blur(18px);
        -webkit-backdrop-filter: blur(18px);
      }

      .brand {
        display: grid;
        gap: 4px;
        text-decoration: none;
      }

      .brand-name {
        font-family: "Space Grotesk", system-ui, sans-serif;
        font-size: 0.98rem;
        font-weight: 700;
        letter-spacing: -0.04em;
      }

      .brand-theme {
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.16em;
        color: var(--muted);
      }

      .nav {
        display: flex;
        align-items: center;
        gap: 16px;
        flex-wrap: wrap;
      }

      .nav a {
        text-decoration: none;
        font-size: 0.84rem;
        font-weight: 600;
        color: var(--muted);
      }

      .nav a:hover,
      .nav a:focus-visible {
        color: var(--accent-deep);
      }

      .hero,
      .sections {
        padding: clamp(18px, 3vw, 28px);
      }

      .hero {
        display: grid;
        grid-template-columns: minmax(0, 0.98fr) minmax(0, 1.02fr);
        gap: 18px;
        align-items: stretch;
      }

      .hero-copy,
      .hero-stage,
      .section-shell,
      .footer-shell {
        border: 1px solid var(--line);
        border-radius: var(--radius-xl);
        background: var(--surface);
      }

      .hero-copy {
        padding: clamp(24px, 4vw, 38px);
      }

      .section-label {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        margin: 0 0 16px;
        font-size: 0.74rem;
        font-weight: 700;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--muted);
      }

      .section-label::before {
        content: "*";
        font-family: "Space Grotesk", system-ui, sans-serif;
        font-size: 1rem;
        color: var(--accent);
      }

      .hero-title {
        margin: 0;
        font-family: "Space Grotesk", system-ui, sans-serif;
        font-size: clamp(2.8rem, 7vw, 4.9rem);
        line-height: 0.94;
        letter-spacing: -0.08em;
        text-wrap: balance;
      }

      .hero-title span {
        display: block;
      }

      .hero-kicker {
        margin: 18px 0 0;
        font-family: "Space Grotesk", system-ui, sans-serif;
        font-size: clamp(1rem, 2vw, 1.22rem);
        line-height: 1.2;
        letter-spacing: -0.03em;
      }

      .hero-statement,
      .hero-support {
        max-width: 38rem;
        line-height: 1.72;
      }

      .hero-statement {
        margin: 22px 0 0;
        font-size: 1.02rem;
      }

      .hero-support {
        margin: 12px 0 0;
        color: var(--muted);
      }

      .hero-marquee {
        margin-top: 22px;
        overflow: hidden;
        border: 1px solid var(--line);
        border-radius: 999px;
        background: var(--surface-strong);
      }

      .hero-marquee-track {
        display: flex;
        width: max-content;
        animation: marquee 18s linear infinite;
      }

      .hero-marquee:hover .hero-marquee-track {
        animation-play-state: paused;
      }

      .hero-marquee-item {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 11px 18px;
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .hero-marquee-item::after {
        content: "*";
        color: var(--accent);
      }

      .hero-stage {
        padding: 20px;
        display: grid;
        gap: 16px;
        align-content: start;
        background:
          radial-gradient(circle at top right, rgba(182, 83, 50, 0.14), transparent 28%),
          linear-gradient(180deg, rgba(252, 246, 239, 0.94), rgba(240, 228, 216, 0.86));
      }

      .hero-stage-main {
        display: grid;
        grid-template-columns: 220px minmax(0, 1fr);
        gap: 16px;
        align-items: stretch;
      }

      .portrait-card,
      .cluster-card,
      .principle-card,
      .project-card,
      .focus-card,
      .tool-group,
      .timeline-list,
      .footer-card {
        border-radius: var(--radius-lg);
        border: 1px solid var(--line);
        background: rgba(255, 249, 242, 0.8);
      }

      .portrait-card {
        padding: 12px;
        display: grid;
        gap: 12px;
        box-shadow: 0 16px 32px rgba(0, 0, 0, 0.08);
      }

      .portrait-card :global(.portrait-image) {
        width: 100%;
        aspect-ratio: 0.92;
        object-fit: cover;
        object-position: center top;
        border-radius: 20px;
      }

      .portrait-meta {
        display: grid;
        gap: 4px;
      }

      .portrait-meta strong {
        font-size: 0.96rem;
      }

      .portrait-meta span {
        color: var(--muted);
        font-size: 0.84rem;
      }

      .hero-cluster {
        display: grid;
        gap: 12px;
      }

      .cluster-card {
        display: grid;
        grid-template-columns: auto minmax(0, 1fr);
        gap: 14px;
        align-items: center;
        padding: 14px;
        text-decoration: none;
        transition: transform 0.22s ease, border-color 0.22s ease;
      }

      .cluster-card:hover {
        transform: translateY(-3px);
        border-color: var(--line-strong);
      }

      .cluster-copy {
        display: grid;
        gap: 4px;
      }

      .cluster-type,
      .project-type {
        margin: 0;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--accent-deep);
      }

      .cluster-copy strong,
      .project-copy h3,
      .focus-card h3,
      .principle-card h3,
      .footer-card h3,
      .timeline-copy h3,
      .tool-group h3 {
        font-family: "Space Grotesk", system-ui, sans-serif;
        letter-spacing: -0.05em;
      }

      .cluster-copy strong {
        font-size: 1.02rem;
      }

      .cluster-copy span,
      .principle-card p,
      .project-copy p,
      .focus-card p,
      .tool-group p,
      .timeline-copy p,
      .footer-card p {
        color: var(--muted);
        line-height: 1.65;
      }

      .hero-notes {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
      }

      .hero-note {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 14px;
        border-radius: 999px;
        border: 1px solid var(--line);
        background: rgba(255, 251, 247, 0.9);
        font-size: 0.8rem;
        font-weight: 700;
      }

      .hero-note::before {
        content: "*";
        color: var(--accent);
      }

      .bundle {
        position: relative;
        width: 110px;
        height: 86px;
        flex-shrink: 0;
      }

      .bundle-tile {
        position: absolute;
        border-radius: 22px;
        border: 1px solid rgba(255, 255, 255, 0.46);
        background-image:
          linear-gradient(180deg, rgba(22, 18, 16, 0.04), rgba(22, 18, 16, 0.22)),
          var(--asset);
        background-size: cover;
        box-shadow: 0 14px 24px rgba(0, 0, 0, 0.12);
      }

      .bundle-tile-a {
        width: 56px;
        height: 56px;
        left: 0;
        bottom: 10px;
        transform: rotate(-10deg);
        background-position: top center;
      }

      .bundle-tile-b {
        width: 60px;
        height: 60px;
        left: 28px;
        top: 4px;
        transform: rotate(8deg);
        background-position: center center;
      }

      .bundle-tile-c {
        width: 50px;
        height: 50px;
        right: 2px;
        bottom: 0;
        background-position: bottom center;
      }

      .bundle-tone-1 .bundle-tile-b {
        box-shadow: 0 16px 28px rgba(182, 83, 50, 0.2);
      }

      .bundle-tone-2 .bundle-tile-b {
        box-shadow: 0 16px 28px rgba(126, 50, 29, 0.24);
      }

      .bundle-tone-3 .bundle-tile-b {
        box-shadow: 0 16px 28px rgba(95, 65, 56, 0.24);
      }

      .sections {
        display: grid;
        gap: 18px;
        padding-top: 0;
      }

      .section-shell,
      .footer-shell {
        padding: clamp(22px, 3vw, 30px);
      }

      .section-head {
        display: grid;
        gap: 10px;
        margin-bottom: 18px;
        max-width: 48rem;
      }

      .section-head h2 {
        margin: 0;
        font-family: "Space Grotesk", system-ui, sans-serif;
        font-size: clamp(1.9rem, 4vw, 2.8rem);
        line-height: 0.98;
        letter-spacing: -0.06em;
        text-wrap: balance;
      }

      .section-head p {
        margin: 0;
        color: var(--muted);
        line-height: 1.72;
      }

      .principles-grid,
      .focus-grid,
      .tool-groups,
      .footer-grid {
        display: grid;
        gap: 14px;
      }

      .principles-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .principle-card,
      .focus-card,
      .tool-group,
      .footer-card {
        padding: 20px;
      }

      .principle-card h3,
      .focus-card h3,
      .project-copy h3,
      .timeline-copy h3,
      .footer-card h3,
      .tool-group h3 {
        margin: 0;
        font-size: 1.2rem;
        line-height: 1.05;
      }

      .work-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 14px;
      }

      .project-card {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 16px;
        align-items: center;
        padding: 18px 20px;
      }

      .project-copy {
        display: grid;
        gap: 6px;
      }

      .project-copy h3 {
        margin: 0;
        font-size: 1.16rem;
      }

      .project-link,
      .contact-link,
      .signal-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
        font-weight: 700;
      }

      .project-link {
        margin-top: 6px;
        color: var(--accent-deep);
      }

      .project-link::after,
      .contact-link::after,
      .signal-link::after {
        content: "↗";
      }

      .skills-layout {
        display: grid;
        grid-template-columns: minmax(0, 0.82fr) minmax(0, 1.18fr);
        gap: 14px;
      }

      .focus-grid {
        align-content: start;
      }

      .tool-groups {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .tool-group p {
        margin: 10px 0 0;
      }

      .timeline-list {
        padding: 10px;
      }

      .timeline-row {
        display: grid;
        grid-template-columns: 170px minmax(0, 1fr);
        gap: 18px;
        padding: 18px 14px;
      }

      .timeline-row + .timeline-row {
        border-top: 1px solid var(--line);
      }

      .timeline-date {
        margin: 0;
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--accent-deep);
      }

      .timeline-role {
        margin: 6px 0 0;
        font-weight: 700;
      }

      .footer-grid {
        grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
      }

      .contact-links,
      .signal-links {
        display: grid;
        gap: 10px;
        margin-top: 16px;
      }

      .contact-link,
      .signal-link {
        justify-content: space-between;
        padding: 14px 16px;
        border-radius: 18px;
        border: 1px solid var(--line);
        background: var(--surface-strong);
      }

      .footer-meta {
        margin-top: 18px;
        padding-top: 16px;
        border-top: 1px solid var(--line);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
        color: var(--muted);
        font-size: 0.86rem;
      }

      .footer-note {
        font-weight: 700;
        color: var(--accent-deep);
      }

      [data-reveal] {
        opacity: 0;
        transform: translateY(22px);
        transition:
          opacity 0.7s ease,
          transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
        transition-delay: var(--delay, 0ms);
      }

      [data-reveal].revealed {
        opacity: 1;
        transform: translateY(0);
      }

      @keyframes marquee {
        from {
          transform: translateX(0);
        }
        to {
          transform: translateX(-50%);
        }
      }

      @media (max-width: 1100px) {
        .hero,
        .skills-layout,
        .footer-grid {
          grid-template-columns: 1fr;
        }

        .principles-grid,
        .work-grid,
        .tool-groups {
          grid-template-columns: 1fr 1fr;
        }
      }

      @media (max-width: 820px) {
        .page {
          width: min(calc(100% - 16px), var(--max));
          border-radius: 28px;
        }

        .topbar {
          align-items: flex-start;
          flex-direction: column;
        }

        .hero-stage-main,
        .principles-grid,
        .work-grid,
        .tool-groups,
        .footer-grid {
          grid-template-columns: 1fr;
        }

        .portrait-card {
          max-width: 260px;
        }

        .timeline-row {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 640px) {
        .hero,
        .sections {
          padding: 14px;
        }

        .hero-copy,
        .hero-stage,
        .section-shell,
        .footer-shell {
          border-radius: 24px;
        }

        .project-card,
        .cluster-card {
          grid-template-columns: 1fr;
          justify-items: start;
        }

        .bundle {
          width: 96px;
          height: 78px;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
        }

        .hero-marquee-track {
          animation: none;
        }

        [data-reveal] {
          opacity: 1;
          transform: none;
          transition: none;
        }
      }
    </style>
  </head>
  <body>
    <div class="page">
      <header class="topbar">
        <a class="brand" href="#top">
          <span class="brand-name">{portfolioIdentity.name}</span>
          <span class="brand-theme">{theme4Content.themeName}</span>
        </a>

        <nav class="nav" aria-label={theme4Content.themeName}>
          {theme4Content.navItems.map((item) => (
            <a href={item.href}>{item.label}</a>
          ))}
        </nav>
      </header>

      <main>
        <section class="hero">
          <div class="hero-copy" data-reveal>
            <p class="section-label">{theme4Content.hero.eyebrow}</p>
            <h1 class="hero-title">
              {theme4Content.hero.headlineLines.map((line) => (
                <span>{line}</span>
              ))}
            </h1>
            <p class="hero-kicker">{theme4Content.hero.title}</p>
            <p class="hero-statement">{theme4Content.hero.statement}</p>
            <p class="hero-support">{theme4Content.hero.supportingBlurb}</p>

            <div class="hero-marquee" aria-hidden="true">
              <div class="hero-marquee-track">
                {[...theme4Content.hero.tickerPhrases, ...theme4Content.hero.tickerPhrases].map((phrase) => (
                  <span class="hero-marquee-item">{phrase}</span>
                ))}
              </div>
            </div>
          </div>

          <div class="hero-stage" data-reveal style="--delay:100ms">
            <div class="hero-stage-main">
              <div class="portrait-card">
                <Image
                  src={profileImage.src}
                  width={profileImage.width}
                  height={profileImage.height}
                  alt={theme4Content.profileAlt}
                  class="portrait-image"
                />
                <div class="portrait-meta">
                  <strong>{portfolioIdentity.name}</strong>
                  <span>{portfolioIdentity.headline}</span>
                </div>
              </div>

              <div class="hero-cluster">
                {heroProjects.map((item, index) => (
                  <a
                    class="cluster-card"
                    href={item.link}
                    target="_blank"
                    rel="noreferrer"
                    data-reveal
                    style={`--delay:${index * 80}ms`}
                  >
                    <div class:list={["bundle", `bundle-tone-${(index % 3) + 1}`]} style={`--asset:url(${item.asset})`}>
                      <span class="bundle-tile bundle-tile-a"></span>
                      <span class="bundle-tile bundle-tile-b"></span>
                      <span class="bundle-tile bundle-tile-c"></span>
                    </div>
                    <div class="cluster-copy">
                      <p class="cluster-type">{item.type}</p>
                      <strong>{item.name}</strong>
                      <span>{item.message}</span>
                    </div>
                  </a>
                ))}
              </div>
            </div>

            <div class="hero-notes">
              {theme4Content.hero.floatingCards.map((item) => (
                <span class="hero-note">{item}</span>
              ))}
            </div>
          </div>
        </section>

        <div class="sections">
          <section class="section-shell" data-reveal>
            <div class="section-head">
              <p class="section-label">{theme4Content.principles.sectionLabel}</p>
              <h2>{theme4Content.principles.heading}</h2>
            </div>

            <div class="principles-grid">
              {theme4Content.principles.items.map((item, index) => (
                <article class="principle-card" data-reveal style={`--delay:${index * 70}ms`}>
                  <h3>{item.title}</h3>
                  <p>{item.body}</p>
                </article>
              ))}
            </div>
          </section>

          <section class="section-shell" id="work" data-reveal>
            <div class="section-head">
              <p class="section-label">{theme4Content.work.sectionLabel}</p>
              <h2>{theme4Content.work.heading}</h2>
              <p>{theme4Content.work.blurb}</p>
            </div>

            <div class="work-grid">
              {work.map((item, index) => (
                <article class="project-card" data-reveal style={`--delay:${index * 50}ms`}>
                  <div class="project-copy">
                    <p class="project-type">{item.type}</p>
                    <h3>{item.name}</h3>
                    <p>{item.message}</p>
                    <a
                      class="project-link"
                      href={item.link}
                      target="_blank"
                      rel="noreferrer"
                      aria-label={`${theme4Content.work.openProjectLabel}: ${item.name}`}
                    >
                      {theme4Content.work.openProjectLabel}
                    </a>
                  </div>

                  <div class:list={["bundle", item.bundleClass]} style={`--asset:url(${item.asset})`}>
                    <span class="bundle-tile bundle-tile-a"></span>
                    <span class="bundle-tile bundle-tile-b"></span>
                    <span class="bundle-tile bundle-tile-c"></span>
                  </div>
                </article>
              ))}
            </div>
          </section>

          <section class="section-shell" id="stack" data-reveal>
            <div class="section-head">
              <p class="section-label">{theme4Content.skills.sectionLabel}</p>
              <h2>{theme4Content.skills.heading}</h2>
              <p>{theme4Content.skills.blurb}</p>
            </div>

            <div class="skills-layout">
              <div class="focus-grid">
                {theme4Content.skills.focusAreas.map((item, index) => (
                  <article class="focus-card" data-reveal style={`--delay:${index * 70}ms`}>
                    <h3>{item.title}</h3>
                    <p>{item.body}</p>
                  </article>
                ))}
              </div>

              <div class="tool-groups">
                {toolGroups.map((group, index) => (
                  <article class="tool-group" data-reveal style={`--delay:${index * 60}ms`}>
                    <h3>{group.title}</h3>
                    <p>{group.items.join(" • ")}</p>
                  </article>
                ))}
              </div>
            </div>
          </section>

          <section class="section-shell" id="experience" data-reveal>
            <div class="section-head">
              <p class="section-label">{theme4Content.experience.sectionLabel}</p>
              <h2>{theme4Content.experience.heading}</h2>
              <p>{theme4Content.experience.blurb}</p>
            </div>

            <div class="timeline-list">
              {experienceTimeline.map((item, index) => (
                <article class="timeline-row" data-reveal style={`--delay:${index * 45}ms`}>
                  <p class="timeline-date">{item.dates}</p>
                  <div class="timeline-copy">
                    <h3>{item.company}</h3>
                    <p class="timeline-role">{item.role}</p>
                    {item.note && <p>{item.note}</p>}
                  </div>
                </article>
              ))}
            </div>
          </section>

          <section class="footer-shell" id="contact" data-reveal>
            <div class="section-head">
              <p class="section-label">{theme4Content.contact.sectionLabel}</p>
              <h2>{theme4Content.contact.heading}</h2>
              <p>{theme4Content.contact.blurb}</p>
            </div>

            <div class="footer-grid">
              <article class="footer-card" data-reveal>
                <h3>{theme4Content.contact.heading}</h3>
                <div class="contact-links">
                  {theme4Content.contact.links.map((item) => (
                    <a
                      class="contact-link"
                      href={contactHrefMap[item.key]}
                      target={item.key === "email" ? undefined : "_blank"}
                      rel={item.key === "email" ? undefined : "noreferrer"}
                    >
                      <span>{item.label}</span>
                    </a>
                  ))}
                </div>
              </article>

              <article class="footer-card" data-reveal style="--delay:70ms">
                <p class="section-label">{theme4Content.notes.sectionLabel}</p>
                <h3>{theme4Content.notes.writingHeading}</h3>
                <div class="signal-links">
                  <a class="signal-link" href={primaryArticle.link} target="_blank" rel="noreferrer">
                    <span>{primaryArticle.title}</span>
                  </a>
                </div>

                <h3 style="margin-top: 22px;">{theme4Content.notes.openSourceHeading}</h3>
                <div class="signal-links">
                  {openSourceLinks.map((link) => (
                    <a class="signal-link" href={link} target="_blank" rel="noreferrer">
                      <span>{link.replace("https://github.com/", "")}</span>
                    </a>
                  ))}
                </div>
              </article>
            </div>

            <div class="footer-meta">
              <span class="footer-note">{theme4Content.notes.footerNote}</span>
              <span>{theme4Content.themeName}</span>
            </div>
          </section>
        </div>
      </main>
    </div>

    <ThemeSwitcher
      themeNumber={4}
      fontFamily="'Space Grotesk', system-ui, sans-serif"
      primaryColor="#f7eee5"
      accentColor="#7e321d"
    />

    <script>
      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      if (!reduceMotion) {
        const revealElements = document.querySelectorAll("[data-reveal]");
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("revealed");
                observer.unobserve(entry.target);
              }
            });
          },
          {
            threshold: 0.14,
            rootMargin: "0px 0px -8% 0px",
          }
        );

        revealElements.forEach((element) => observer.observe(element));
      } else {
        document.querySelectorAll("[data-reveal]").forEach((element) => {
          element.classList.add("revealed");
        });
      }
    </script>
  </body>
</html>
