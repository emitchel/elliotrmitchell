---
import {
  contactDetails,
  experienceTimeline,
  openSourceLinks,
  theme2Content,
  portfolioIdentity,
  profileImages,
  skillTags,
  workItems,
  writingArticles,
} from "../../content/portfolioContent.js";
import ThemeSwitcher from "../../components/ThemeSwitcher.astro";

const profileImage = profileImages.profile5;
const primaryArticle = writingArticles[0];
const emailHref = `mailto:${contactDetails.email}`;
const work = workItems;
const openSource = openSourceLinks;
const skills = skillTags;
const experience = experienceTimeline;
const page2Hero = theme2Content.hero;
const page2About = theme2Content.about;
const page2Writing = theme2Content.writing;
const page2Skills = theme2Content.skills;
const page2Contact = theme2Content.contact;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{portfolioIdentity.name}</title>
    <meta
      name="description"
      content="Theme 2 for Elliot Mitchell's portfolio: a minimal editorial layout focused on shipped Android work, leadership, and craft."
    />
    <link rel="icon" type="image/png" href="/assets/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Newsreader:opsz,wght@6..72,400;6..72,500;6..72,700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/assets/fontawesome.css" />

    <style is:inline>
      *, *::before, *::after {
        box-sizing: border-box;
      }

      :root {
        --bg: #f3efe7;
        --paper: rgba(255, 252, 246, 0.84);
        --card: rgba(255, 255, 255, 0.62);
        --ink: #1d1b19;
        --muted: #645d56;
        --line: rgba(29, 27, 25, 0.12);
        --strong-line: rgba(29, 27, 25, 0.24);
        --accent: #9f6848;
        --shadow: 0 20px 70px rgba(47, 34, 22, 0.08);
        --max: 1180px;
        --radius: 28px;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        min-height: 100vh;
        font-family: "Manrope", system-ui, sans-serif;
        color: var(--ink);
        background:
          radial-gradient(circle at top left, rgba(159, 104, 72, 0.15), transparent 34%),
          radial-gradient(circle at top right, rgba(114, 134, 116, 0.12), transparent 36%),
          linear-gradient(180deg, #f7f3ec 0%, var(--bg) 46%, #efe6db 100%);
        -webkit-font-smoothing: antialiased;
      }

      a {
        color: inherit;
      }

      img {
        display: block;
        max-width: 100%;
      }

      .shell {
        width: min(calc(100% - 32px), var(--max));
        margin: 20px auto;
        background: var(--paper);
        border: 1px solid var(--line);
        border-radius: 32px;
        box-shadow: var(--shadow);
        overflow: hidden;
        backdrop-filter: blur(18px);
        -webkit-backdrop-filter: blur(18px);
      }

      .topbar {
        position: sticky;
        top: 0;
        z-index: 10;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding: 18px 24px;
        background: rgba(255, 252, 246, 0.86);
        border-bottom: 1px solid var(--line);
        backdrop-filter: blur(18px);
        -webkit-backdrop-filter: blur(18px);
      }

      .theme-mark {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        font-size: 12px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--muted);
        text-decoration: none;
      }

      .theme-mark strong {
        color: var(--ink);
        letter-spacing: 0.1em;
      }

      .topnav {
        display: flex;
        align-items: center;
        gap: 20px;
        flex-wrap: wrap;
      }

      .topnav a {
        text-decoration: none;
        font-size: 13px;
        color: var(--muted);
      }

      .topnav a:hover {
        color: var(--ink);
      }

      .hero {
        display: grid;
        grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
        gap: 28px;
        padding: 28px;
      }

      .hero-copy,
      .hero-panel,
      .section-block,
      .contact-block {
        background: var(--card);
        border: 1px solid var(--line);
        border-radius: var(--radius);
      }

      .hero-copy {
        padding: clamp(28px, 4vw, 52px);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        min-height: 620px;
      }

      .eyebrow,
      .section-label {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        margin: 0 0 20px;
        font-size: 12px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--muted);
      }

      .eyebrow::before,
      .section-label::before {
        content: "";
        width: 42px;
        height: 1px;
        background: var(--strong-line);
      }

      .hero-name {
        margin: 0;
        font-family: "Newsreader", Georgia, serif;
        font-size: clamp(4.4rem, 12vw, 8.5rem);
        line-height: 0.94;
        letter-spacing: -0.06em;
      }

      .hero-name span {
        display: block;
      }

      .hero-title {
        margin: 18px 0 0;
        max-width: 18ch;
        font-size: clamp(1.15rem, 2.4vw, 1.7rem);
        line-height: 1.3;
        color: var(--muted);
      }

      .hero-sub {
        max-width: 33rem;
        margin: 24px 0 0;
        font-size: 1.05rem;
        line-height: 1.8;
      }

      .hero-actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        margin-top: 30px;
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 7px;
        min-height: 46px;
        padding: 0 18px;
        border-radius: 999px;
        border: 1px solid var(--strong-line);
        font-size: 14px;
        font-weight: 700;
        text-decoration: none;
      }

      .button.primary {
        background: var(--ink);
        color: #f8f2ea;
        border-color: var(--ink);
      }

      .button.secondary {
        background: transparent;
        color: var(--ink);
      }

      .hero-notes {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 12px;
        margin-top: 42px;
      }

      .note {
        padding: 16px 18px;
        border-radius: 20px;
        background: rgba(255, 255, 255, 0.52);
        border: 1px solid var(--line);
      }

      .note-value {
        display: block;
        margin-bottom: 4px;
        font-family: "Newsreader", Georgia, serif;
        font-size: 2rem;
        line-height: 1;
      }

      .note-label {
        font-size: 12px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--muted);
      }

      .hero-panel {
        overflow: hidden;
        position: relative;
        display: grid;
        grid-template-rows: 1fr auto;
        min-height: 620px;
      }

      .hero-photo-wrap {
        padding: 20px;
      }

      .hero-photo {
        height: 100%;
        min-height: 420px;
        border-radius: calc(var(--radius) - 8px);
        object-fit: cover;
        object-position: center 20%;
        filter: saturate(0.95) contrast(1.02);
      }

      .hero-panel-copy {
        padding: 24px 24px 26px;
        border-top: 1px solid var(--line);
        display: grid;
        gap: 12px;
      }

      .hero-panel-copy p {
        margin: 0;
      }

      .panel-kicker {
        font-size: 12px;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--muted);
      }

      .panel-line {
        font-size: 1rem;
        line-height: 1.7;
      }

      .stack {
        display: grid;
        gap: 28px;
        padding: 0 28px 28px;
      }

      .section-block {
        padding: 28px;
      }

      .about-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.4fr) minmax(240px, 0.8fr);
        gap: 24px;
        align-items: start;
      }

      .about-copy {
        display: grid;
        gap: 20px;
      }

      .section-heading {
        margin: 0;
        font-family: "Newsreader", Georgia, serif;
        font-size: clamp(2.2rem, 4vw, 4rem);
        line-height: 0.98;
        letter-spacing: -0.05em;
      }

      .lede {
        margin: 0;
        max-width: 46rem;
        font-size: 1.05rem;
        line-height: 1.85;
      }

      .meta-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
      }

      .meta-card {
        padding: 18px;
        border-radius: 20px;
        background: rgba(255, 255, 255, 0.4);
        border: 1px solid var(--line);
      }

      .meta-card h3 {
        margin: 0 0 8px;
        font-size: 13px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--muted);
      }

      .meta-card p {
        margin: 0;
        font-size: 15px;
        line-height: 1.7;
      }

      .aside-quote {
        padding: 22px;
        border-radius: 24px;
        background: linear-gradient(180deg, rgba(159, 104, 72, 0.08), rgba(159, 104, 72, 0.02));
        border: 1px solid rgba(159, 104, 72, 0.14);
      }

      .aside-quote p {
        margin: 0;
        font-family: "Newsreader", Georgia, serif;
        font-size: 1.7rem;
        line-height: 1.16;
        letter-spacing: -0.03em;
      }

      .work-layout {
        display: grid;
        grid-template-columns: minmax(0, 1.55fr) minmax(280px, 0.7fr);
        gap: 24px;
      }

      .work-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 16px;
      }

      .work-card {
        display: grid;
        gap: 16px;
        padding: 16px;
        border-radius: 24px;
        background: rgba(255, 255, 255, 0.46);
        border: 1px solid var(--line);
        text-decoration: none;
        transition: transform 0.24s ease, border-color 0.24s ease, box-shadow 0.24s ease;
      }

      .work-card:hover {
        transform: translateY(-3px);
        border-color: var(--strong-line);
        box-shadow: 0 18px 36px rgba(48, 35, 24, 0.08);
      }

      .work-card:nth-child(3n + 1) .work-thumb {
        background: linear-gradient(180deg, #efe7dd, #e2d6c8);
      }

      .work-card:nth-child(3n + 2) .work-thumb {
        background: linear-gradient(180deg, #ecece6, #d9ddd2);
      }

      .work-card:nth-child(3n) .work-thumb {
        background: linear-gradient(180deg, #efe4df, #e7d2c8);
      }

      .work-thumb {
        aspect-ratio: 16 / 11;
        border-radius: 18px;
        overflow: hidden;
        padding: 16px;
        display: grid;
        place-items: center;
      }

      .work-media {
        width: min(46%, 132px);
        height: 100%;
        aspect-ratio: 9 / 16;
        border-radius: 16px;
        overflow: hidden;
        border: 1px solid rgba(29, 27, 25, 0.12);
        background: rgba(255, 255, 255, 0.4);
        box-shadow: 0 16px 28px rgba(29, 27, 25, 0.14);
      }

      .work-media img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center top;
        transform: scale(1.02);
        animation: work-pan 18s ease-in-out infinite alternate;
      }

      .work-card:nth-child(2n) .work-media img {
        animation-duration: 22s;
      }

      .work-card:nth-child(3n) .work-media img {
        animation-duration: 20s;
      }

      @keyframes work-pan {
        from {
          object-position: center 0%;
          transform: scale(1.02);
        }

        to {
          object-position: center 100%;
          transform: scale(1.02);
        }
      }

      .work-type {
        display: inline-flex;
        width: fit-content;
        padding: 7px 10px;
        border-radius: 999px;
        background: rgba(29, 27, 25, 0.06);
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--muted);
      }

      .work-name {
        margin: 0;
        font-size: 1.05rem;
        font-weight: 800;
      }

      .work-message {
        margin: 8px 0 0;
        font-size: 14px;
        line-height: 1.7;
        color: var(--muted);
      }

      .rail {
        display: grid;
        gap: 16px;
        align-content: start;
      }

      .rail-card {
        padding: 20px;
        border-radius: 24px;
        background: rgba(255, 255, 255, 0.42);
        border: 1px solid var(--line);
      }

      .rail-card h3 {
        margin: 0 0 14px;
        font-size: 14px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--muted);
      }

      .rail-list {
        display: grid;
        gap: 12px;
      }

      .rail-list a {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 12px;
        padding-bottom: 12px;
        border-bottom: 1px solid var(--line);
        text-decoration: none;
      }

      .rail-list a:last-child {
        padding-bottom: 0;
        border-bottom: 0;
      }

      .rail-list span {
        font-size: 15px;
        line-height: 1.5;
      }

      .rail-list strong {
        font-size: 14px;
        color: var(--muted);
      }

      .article-link {
        display: grid;
        gap: 8px;
        text-decoration: none;
      }

      .article-link p {
        margin: 0;
      }

      .article-kicker {
        font-size: 12px;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--muted);
      }

      .article-title {
        font-family: "Newsreader", Georgia, serif;
        font-size: 1.7rem;
        line-height: 1.1;
        letter-spacing: -0.03em;
      }

      .article-copy {
        color: var(--muted);
        line-height: 1.7;
      }

      .skills-wrap {
        display: grid;
        gap: 20px;
      }

      .skills-copy {
        display: flex;
        align-items: end;
        justify-content: space-between;
        gap: 20px;
        flex-wrap: wrap;
      }

      .skills-copy p {
        margin: 0;
        max-width: 40rem;
        line-height: 1.8;
        color: var(--muted);
      }

      .pill-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
      }

      .pill {
        display: inline-flex;
        align-items: center;
        min-height: 40px;
        padding: 0 14px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.56);
        border: 1px solid var(--line);
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0.01em;
      }

      .timeline {
        display: grid;
        gap: 0;
      }

      .timeline-row {
        display: grid;
        grid-template-columns: 170px minmax(0, 1fr);
        gap: 18px;
        padding: 18px 0;
        border-top: 1px solid var(--line);
      }

      .timeline-row:first-of-type {
        border-top: 0;
        padding-top: 6px;
      }

      .timeline-dates {
        font-size: 12px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--muted);
      }

      .timeline-main {
        display: grid;
        gap: 6px;
      }

      .timeline-company {
        margin: 0;
        font-size: 1rem;
        font-weight: 800;
      }

      .timeline-role {
        margin: 0;
        color: var(--muted);
      }

      .timeline-note {
        margin: 0;
        line-height: 1.7;
      }

      .contact-block {
        padding: 28px;
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 18px;
        align-items: end;
      }

      .contact-heading {
        margin: 0;
        font-family: "Newsreader", Georgia, serif;
        font-size: clamp(2.2rem, 5vw, 4.2rem);
        line-height: 0.96;
        letter-spacing: -0.05em;
      }

      .contact-copy {
        margin: 12px 0 0;
        max-width: 34rem;
        line-height: 1.8;
        color: var(--muted);
      }

      .contact-actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        justify-content: flex-end;
      }

      .footer {
        padding: 18px 28px 28px;
        font-size: 12px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--muted);
      }

      @media (max-width: 1040px) {
        .hero,
        .work-layout,
        .about-grid,
        .contact-block {
          grid-template-columns: 1fr;
        }

        .hero-copy,
        .hero-panel {
          min-height: auto;
        }

        .hero-photo {
          min-height: 380px;
        }

        .contact-actions {
          justify-content: flex-start;
        }
      }

      @media (max-width: 780px) {
        .shell {
          width: min(calc(100% - 20px), var(--max));
          margin: 10px auto;
          border-radius: 24px;
        }

        .topbar,
        .hero,
        .stack,
        .footer {
          padding-left: 18px;
          padding-right: 18px;
        }

        .hero,
        .stack {
          gap: 18px;
        }

        .hero {
          padding-top: 18px;
        }

        .hero-notes,
        .meta-grid,
        .work-grid {
          grid-template-columns: 1fr;
        }

        .timeline-row {
          grid-template-columns: 1fr;
          gap: 6px;
        }

        .topnav {
          display: none;
        }
      }

      @media (max-width: 560px) {
        .hero-copy,
        .section-block,
        .contact-block,
        .hero-panel-copy,
        .hero-photo-wrap {
          padding: 20px;
        }

        .hero-copy {
          min-height: 0;
        }

        .hero-name {
          font-size: clamp(3.5rem, 18vw, 5.2rem);
        }

        .hero-photo {
          min-height: 320px;
        }

        .button {
          width: 100%;
        }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <header class="topbar">
        <a class="theme-mark" href="#top">
          <strong>02</strong>
          <span>Field Notes</span>
        </a>

        <nav class="topnav" aria-label="Section navigation">
          <a href="#about">About</a>
          <a href="#work">Work</a>
          <a href="#skills">Skills</a>
          <a href="#experience">Experience</a>
          <a href="#contact">Contact</a>
        </nav>
      </header>

      <main id="top">
        <section class="hero">
          <div class="hero-copy">
            <div>
              <p class="eyebrow">{portfolioIdentity.headline}</p>
              <h1 class="hero-name">
                <span>{portfolioIdentity.name.split(" ")[0]}</span>
                <span>{portfolioIdentity.name.split(" ").slice(1).join(" ")}</span>
              </h1>
              <p class="hero-title">{portfolioIdentity.subheadline}</p>
            </div>

            <div>
              <p class="hero-sub">{page2Hero.supportingBlurb}</p>
              <div class="hero-notes" aria-label="Summary statistics">
                {page2Hero.summaryStats.map((stat) => (
                  <div class="note">
                    <span class="note-value">{stat.value}</span>
                    <span class="note-label">{stat.label}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>

          <aside class="hero-panel" aria-label="Profile">
            <div class="hero-photo-wrap">
              <img class="hero-photo" src={profileImage} alt={portfolioIdentity.name} />
            </div>
            <div class="hero-panel-copy">
              <p class="panel-kicker">{page2Hero.currentFocusLabel}</p>
              <p class="panel-line">{page2Hero.currentFocusBlurb}</p>
            </div>
          </aside>
        </section>

        <div class="stack">
          <section id="about" class="section-block">
            <p class="section-label">About</p>
            <div class="about-grid">
              <div class="about-copy">
                <h2 class="section-heading">{page2About.heading}</h2>
                <p class="lede">{page2About.body}</p>
                <div class="meta-grid">
                  <div class="meta-card">
                    <h3>{page2About.currentRoleLabel}</h3>
                    <p>{page2About.currentRoleBlurb}</p>
                  </div>
                  <div class="meta-card">
                    <h3>{page2About.previousRoleLabel}</h3>
                    <p>{page2About.previousRoleBlurb}</p>
                  </div>
                </div>
              </div>

              <div class="aside-quote">
                <p>{page2About.quoteText}</p>
                <p class="aside-attribution">{page2About.quoteAttribution}</p>
              </div>
            </div>
          </section>

          <section id="work" class="section-block">
            <p class="section-label">Work</p>
            <div class="work-layout">
              <div class="work-grid">
                {work.map((project) => (
                  <a class="work-card" href={project.link} target="_blank" rel="noopener noreferrer">
                    <div class="work-thumb">
                      <div class="work-media">
                        <img src={project.asset} alt={project.name} loading="lazy" />
                      </div>
                    </div>
                    <div>
                      <span class="work-type">{project.type}</span>
                      <h3 class="work-name">{project.name}</h3>
                      <p class="work-message">{project.message}</p>
                    </div>
                  </a>
                ))}
              </div>

              <aside class="rail">
                <div class="rail-card">
                  <h3>Open source</h3>
                  <div class="rail-list">
                    {openSource.map((link) => (
                      <a href={link} target="_blank" rel="noopener noreferrer">
                        <span>{link.split("/").at(-1)}</span>
                        <strong>GitHub</strong>
                      </a>
                    ))}
                  </div>
                </div>

                <div class="rail-card">
                  <h3>Writing</h3>
                  <a
                    class="article-link"
                    href={primaryArticle.link}
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    <p class="article-kicker">{primaryArticle.publication} / {primaryArticle.source}</p>
                    <p class="article-title">{primaryArticle.title}</p>
                    <p class="article-copy">{page2Writing.articleBlurb}</p>
                  </a>
                </div>
              </aside>
            </div>
          </section>

          <section id="skills" class="section-block">
            <p class="section-label">Skills</p>
            <div class="skills-wrap">
              <div class="skills-copy">
                <h2 class="section-heading">{page2Skills.heading}</h2>
                <p>{page2Skills.blurb}</p>
              </div>
              <div class="pill-grid">
                {skills.map((skill) => <span class="pill">{skill}</span>)}
              </div>
            </div>
          </section>

          <section id="experience" class="section-block">
            <p class="section-label">Experience</p>
            <div class="timeline">
              {experience.map((item) => (
                <article class="timeline-row">
                  <div class="timeline-dates">{item.dates}</div>
                  <div class="timeline-main">
                    <h3 class="timeline-company">{item.company}</h3>
                    <p class="timeline-role">{item.role}</p>
                    {item.note && <p class="timeline-note">{item.note}</p>}
                  </div>
                </article>
              ))}
            </div>
          </section>

          <section id="contact" class="contact-block">
            <div>
              <p class="section-label">Contact</p>
              <h2 class="contact-heading">{page2Contact.heading}</h2>
            </div>

            <div class="contact-actions">
              <a class="button secondary" href={emailHref}><i class="fa fa-envelope-o"></i> Email</a>
              <a class="button secondary" href={contactDetails.stackOverflow} target="_blank" rel="noopener noreferrer"><i class="fa fa-stack-overflow"></i> Stack Overflow</a>
              <a class="button secondary" href={contactDetails.linkedin} target="_blank" rel="noopener noreferrer"><i class="fa fa-linkedin-square"></i> LinkedIn</a>
              <a class="button secondary" href={contactDetails.github} target="_blank" rel="noopener noreferrer"><i class="fa fa-github"></i> GitHub</a>
            </div>
          </section>
        </div>
      </main>

      <footer class="footer">Theme 02 / Field Notes / {portfolioIdentity.name}</footer>
    </div>
    <ThemeSwitcher
      themeNumber={2}
      fontFamily="'Manrope', system-ui, sans-serif"
      primaryColor="#f3efe7"
      accentColor="#9f6848"
    />
  </body>
</html>
