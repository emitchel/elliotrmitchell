---
interface Props {
  src: string;
  alt: string;
  width?: number; // px, default 200 — height auto-derived at 9:20
}

const { src, alt, width = 200 } = Astro.props;
---

<div class="phone-frame" style={`--phone-width: ${width}px`}>
  <span class="btn-vol"></span>
  <span class="btn-vol"></span>
  <span class="btn-power"></span>
  <div class="phone-screen">
    <img class="phone-image" src={src} alt={alt} />
  </div>
</div>

<style>
  .phone-frame {
    position: relative;
    width: var(--phone-width, 160px);
    height: calc(var(--phone-width, 160px) * 20 / 9);
    max-width: 100%;
    background: #141414;
    border-radius: 26px;
    box-shadow:
      inset 0 0 0 1px #3a3a3a,
      0 0 0 1px #0a0a0a,
      0 24px 48px rgba(0, 0, 0, 0.18),
      0 4px 8px rgba(0, 0, 0, 0.12);
    flex-shrink: 1;
    /* no padding — screen is absolutely positioned to the inset area */
  }

  /* punch-hole camera */
  .phone-frame::before {
    content: '';
    position: absolute;
    top: 13px;
    left: 50%;
    transform: translateX(-50%);
    width: 9px;
    height: 9px;
    background: #2a2a2a;
    border-radius: 50%;
    z-index: 3;
  }

  /* home indicator */
  .phone-frame::after {
    content: '';
    position: absolute;
    bottom: 5px;
    left: 50%;
    transform: translateX(-50%);
    width: 44px;
    height: 3px;
    background: #3a3a3a;
    border-radius: 2px;
  }

  /* volume buttons (left side) */
  .btn-vol {
    position: absolute;
    left: -2px;
    top: 56px;
    width: 2px;
    height: 22px;
    background: #2a2a2a;
    border-radius: 1px 0 0 1px;
    display: block;
  }
  .btn-vol + .btn-vol {
    top: 84px;
  }

  /* power button (right side) */
  .btn-power {
    position: absolute;
    right: -2px;
    top: 70px;
    width: 2px;
    height: 30px;
    background: #2a2a2a;
    border-radius: 0 1px 1px 0;
    display: block;
  }

  .phone-screen {
    position: absolute;
    top: 10px;
    left: 7px;
    right: 7px;
    bottom: 12px;
    border-radius: 18px;
    overflow: hidden;
    background: #1a1a1a;
  }

  .phone-screen :global(.phone-image) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    display: block;
  }

  @media (max-width: 768px) {
    .phone-frame {
      --phone-width: clamp(90px, 28vw, 140px);
      height: calc(var(--phone-width) * 20 / 9);
    }
  }
</style>
